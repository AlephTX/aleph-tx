package exchanges

import (
	"bytes"
	"context"
	"encoding/json"
	"fmt"
	"io"
	"log"
	"net/http"
	"time"

	"github.com/AlephTX/aleph-tx/feeder/shm"
	lighterclient "github.com/elliottech/lighter-go/client"
	lighterhttp "github.com/elliottech/lighter-go/client/http"
	"github.com/elliottech/lighter-go/types"
)

// LighterOrderExecutor executes order requests from Rust using lighter-go SDK
type LighterOrderExecutor struct {
	requestBuffer *shm.OrderRequestBuffer
	eventBuffer   *shm.EventRingBuffer
	txClient      *lighterclient.TxClient
	httpClient    *http.Client
	apiBaseURL    string
	accountIndex  int64
	apiKeyIndex   uint8
}

// NewLighterOrderExecutor creates a new order executor
func NewLighterOrderExecutor(
	requestBuffer *shm.OrderRequestBuffer,
	eventBuffer *shm.EventRingBuffer,
	apiKeyPrivateKey string,
	accountIndex int64,
	apiKeyIndex uint8,
) (*LighterOrderExecutor, error) {
	// Create HTTP client
	httpClient := lighterhttp.NewClient("https://mainnet.zklighter.elliot.ai/api/v1")

	// Create TxClient with Poseidon2 + Schnorr signing
	txClient, err := lighterclient.NewTxClient(
		httpClient,
		apiKeyPrivateKey,
		accountIndex,
		apiKeyIndex,
		1, // Chain ID: 1 = Mainnet
	)
	if err != nil {
		return nil, fmt.Errorf("failed to create TxClient: %w", err)
	}

	return &LighterOrderExecutor{
		requestBuffer: requestBuffer,
		eventBuffer:   eventBuffer,
		txClient:      txClient,
		httpClient:    &http.Client{Timeout: 5 * time.Second},
		apiBaseURL:    "https://mainnet.zklighter.elliot.ai/api/v1",
		accountIndex:  accountIndex,
		apiKeyIndex:   apiKeyIndex,
	}, nil
}

// Run starts the order executor loop
func (e *LighterOrderExecutor) Run(ctx context.Context) error {
	log.Printf("lighter-executor: started (account=%d, api_key=%d)", e.accountIndex, e.apiKeyIndex)

	ticker := time.NewTicker(1 * time.Millisecond) // Check every 1ms
	defer ticker.Stop()

	for {
		select {
		case <-ctx.Done():
			return ctx.Err()

		case <-ticker.C:
			// Process all pending requests
			for {
				request := e.requestBuffer.TryRead()
				if request == nil {
					break
				}

				e.handleRequest(request)
			}
		}
	}
}

// handleRequest processes a single order request
func (e *LighterOrderExecutor) handleRequest(request *shm.OrderRequest) {
	switch shm.OrderRequestType(request.RequestType) {
	case shm.OrderRequestPlaceLimit:
		e.handlePlaceLimitOrder(request)

	case shm.OrderRequestCancel:
		e.handleCancelOrder(request)

	default:
		log.Printf("lighter-executor: unknown request type: %d", request.RequestType)
	}
}

// handlePlaceLimitOrder places a limit order using lighter-go SDK
func (e *LighterOrderExecutor) handlePlaceLimitOrder(request *shm.OrderRequest) {
	// Convert side to Lighter format
	isAsk := uint8(0)
	if shm.OrderRequestSide(request.Side) == shm.OrderRequestSell {
		isAsk = 1
	}

	// Convert price/size to Lighter's integer format
	// For WETH-USDC: tick_size=0.01, step_size=0.0001
	priceInt := uint32(request.Price / 0.01)  // Convert to ticks
	sizeInt := int64(request.Size / 0.0001)   // Convert to base units

	// Create order transaction
	txReq := &types.CreateOrderTxReq{
		MarketIndex:      int16(request.MarketID),
		ClientOrderIndex: time.Now().UnixNano(), // Use timestamp as client order ID
		BaseAmount:       sizeInt,
		Price:            priceInt,
		IsAsk:            isAsk,
		Type:             0, // 0 = Limit order
		TimeInForce:      0, // 0 = GTC (Good Till Cancel)
		ReduceOnly:       0,
		TriggerPrice:     0,
		OrderExpiry:      time.Now().Add(24 * time.Hour).UnixMilli(),
	}

	opts := &types.TransactOpts{}

	log.Printf("lighter-executor: placing limit order market=%d side=%v price=%.2f (ticks=%d) size=%.4f (units=%d)",
		request.MarketID, request.Side, request.Price, priceInt, request.Size, sizeInt)

	// Generate signed transaction
	txInfo, err := e.txClient.GetCreateOrderTransaction(txReq, opts)
	if err != nil {
		log.Printf("lighter-executor: ❌ failed to sign order: %v", err)
		e.eventBuffer.PushOrderRejected(
			uint8(ExchangeLighter),
			request.SymbolID,
			0,
		)
		return
	}

	// Submit transaction to Lighter API
	if err := e.submitTransaction(txInfo); err != nil {
		log.Printf("lighter-executor: ❌ failed to submit order: %v", err)
		e.eventBuffer.PushOrderRejected(
			uint8(ExchangeLighter),
			request.SymbolID,
			0,
		)
		return
	}

	log.Printf("lighter-executor: ✅ order submitted successfully")
	// Note: OrderCreated event will come from WebSocket
}

// handleCancelOrder cancels an order using lighter-go SDK
func (e *LighterOrderExecutor) handleCancelOrder(request *shm.OrderRequest) {
	log.Printf("lighter-executor: canceling order id=%d", request.OrderID)

	txReq := &types.CancelOrderTxReq{
		MarketIndex: int16(request.MarketID),
		Index:       int64(request.OrderID),
	}

	opts := &types.TransactOpts{}

	// Generate signed transaction
	txInfo, err := e.txClient.GetCancelOrderTransaction(txReq, opts)
	if err != nil {
		log.Printf("lighter-executor: ❌ failed to sign cancel: %v", err)
		return
	}

	// Submit transaction
	if err := e.submitTransaction(txInfo); err != nil {
		log.Printf("lighter-executor: ❌ failed to submit cancel: %v", err)
		return
	}

	log.Printf("lighter-executor: ✅ cancel submitted: id=%d", request.OrderID)
	// Note: OrderCanceled event will come from WebSocket
}

// submitTransaction submits a signed transaction to Lighter API
func (e *LighterOrderExecutor) submitTransaction(txInfo interface{}) error {
	// Get transaction info as JSON string
	type TxInfoGetter interface {
		GetTxInfo() (string, error)
	}

	getter, ok := txInfo.(TxInfoGetter)
	if !ok {
		return fmt.Errorf("txInfo does not implement GetTxInfo()")
	}

	txInfoStr, err := getter.GetTxInfo()
	if err != nil {
		return fmt.Errorf("failed to serialize tx: %w", err)
	}

	// Parse JSON to get tx data
	var txData map[string]interface{}
	if err := json.Unmarshal([]byte(txInfoStr), &txData); err != nil {
		return fmt.Errorf("failed to parse tx JSON: %w", err)
	}

	// Submit to /api/v1/tx endpoint
	url := e.apiBaseURL + "/tx"
	jsonBytes, err := json.Marshal(txData)
	if err != nil {
		return fmt.Errorf("failed to marshal tx: %w", err)
	}

	req, err := http.NewRequest("POST", url, bytes.NewBuffer(jsonBytes))
	if err != nil {
		return fmt.Errorf("failed to create request: %w", err)
	}

	req.Header.Set("Content-Type", "application/json")

	resp, err := e.httpClient.Do(req)
	if err != nil {
		return fmt.Errorf("HTTP request failed: %w", err)
	}
	defer resp.Body.Close()

	body, err := io.ReadAll(resp.Body)
	if err != nil {
		return fmt.Errorf("failed to read response: %w", err)
	}

	if resp.StatusCode != http.StatusOK {
		return fmt.Errorf("API error (status %d): %s", resp.StatusCode, string(body))
	}

	// Parse response
	var result map[string]interface{}
	if err := json.Unmarshal(body, &result); err != nil {
		return fmt.Errorf("failed to parse response: %w", err)
	}

	// Check for error in response
	if code, ok := result["code"].(float64); ok && code != 0 {
		msg := result["message"]
		return fmt.Errorf("API returned error code %v: %v", code, msg)
	}

	return nil
}
